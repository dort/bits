; "f64_as_i128"
; "inf_f64"
; "neginf_f64"
; "e_f64"
; "pi_f64"
; "tau_f64"
; "phi_f64"
    (f64_constants f64_as_i128 00)
    (f64_constants inf_f64     01)
    (f64_constants neginf_f64  02)
    (f64_constants e_f64       03)
    (f64_constants pi_f64      04)
    (f64_constants tau_f64     05)
    (f64_constants phi_f64     06)
    (exec ((MACRO)) (, (f64_constants $name $n) )
                    (O (+ (example (21 $n) $name (f64_to_string ($name))) )
                       (- (f64_constants $name $n) )
                    )
    )

