    (example (39 00) hypot_f64 (f64_to_string (hypot_f64 (f64_from_string 1.0) (f64_from_string 1.0))))

; "powf_f64"
; "powi_f64"
; "sub_f64"
; "div_f64"
; "sum_f64"
; "product_f64"
; "max_f64"
; "min_f64"
    (f64_arith powf_f64     00)
    (f64_arith powi_f64     01)
    (f64_arith sub_f64      02)
    (f64_arith div_f64      03)
    (f64_arith mod_f64      04)
    (f64_arith sum_f64      05)
    (f64_arith max_f64      06)
    (f64_arith min_f64      07)
    (f64_arith product_i128 08)
    (exec ((MACRO))
        (, (f64_arith $op $n)  )
        (O (+ (example (40 $n) $op (f64_to_string ($op (f64_from_string  10) (f64_from_string 2)))))
           (- (f64_arith $op $n) )
        )
    )

