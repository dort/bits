; "log2_f64"
; "log10_f64"
; "trunc_f64"
; "recip_f64"
; "fract_f64"
; "signum_f64"
    (f64_unary neg_f64    00)
    (f64_unary abs_f64    01)
    (f64_unary floor_f64  02)
    (f64_unary ceil_f64   03)
    (f64_unary round_f64  05)
    (f64_unary sqrt_f64   06)
    (f64_unary cbrt_f64   07)
    (f64_unary exp_f64    08)
    (f64_unary exp2_f64   09)
    (f64_unary ln_f64     10)
    (f64_unary log2_f64   11)
    (f64_unary log10_f64  12)
    (f64_unary trunc_f64  13)
    (f64_unary recip_f64  14)
    (f64_unary fract_f64  15)
    (f64_unary signum_f64 16)
    (exec ((MACRO))
        (, (f64_unary $op $n) )
        (O (+ (example (36 $n) $op (f64_to_string ($op (pi_f64)))) )
           (- (f64_unary $op $n) )
        )
    )


